{
	"name": "@untemps/svelte-palette",
	"version": "6.0.0-beta.5",
	"author": "Vincent Le Badezet <v.lebadezet@untemps.net>",
	"license": "MIT",
	"homepage": "https://svelte-palette.vercel.app",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/untemps/svelte-palette.git"
	},
	"bugs": "https://github.com/untemps/svelte-palette/issues",
	"description": "Svelte component to display a customisable color picker",
	"keywords": [
		"palette",
		"color",
		"color-picker",
		"svelte",
		"svelte-component",
		"component",
		"javascript"
	],
	"private": false,
	"publishConfig": {
		"access": "public"
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"files": [
		"dist",
		"!dist/**/*.test.*"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./types": {
			"types": "./dist/types.d.ts"
		}
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.6",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.5.16",
		"@sveltejs/package": "^2.3.2",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@testing-library/jest-dom": "^6.4.6",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.5.2",
		"@vitest/coverage-v8": "^4.1.0",
		"carbon-components-svelte": "^0.110.0",
		"carbon-icons-svelte": "^13.13.0",
		"font-color-contrast": "^11.1.0",
		"husky": "^9.0.11",
		"jsdom": "^29.1.1",
		"prettier": "^3.3.2",
		"prettier-plugin-svelte": "^4.1.1",
		"publint": "^0.3.21",
		"semantic-release": "^25.0.3",
		"svelte": "^5.53.5",
		"svelte-check": "^4.7.3",
		"tslib": "^2.6.3",
		"typescript": "^6.0.3",
		"vite": "^8.0.0",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@untemps/svelte-use-drop-outside": "^1.7.0",
		"@untemps/svelte-use-tooltip": "^4.0.0",
		"@untemps/utils": "^3.0.0"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"release": {
		"branches": [
			"main",
			{
				"name": "beta",
				"prerelease": true
			}
		],
		"plugins": [
			[
				"@semantic-release/commit-analyzer",
				{
					"releaseRules": [
						{
							"scope": "force",
							"release": "patch"
						}
					]
				}
			],
			"@semantic-release/release-notes-generator",
			"@semantic-release/changelog",
			"@semantic-release/npm",
			"@semantic-release/git",
			[
				"@semantic-release/github",
				{
					"assets": [
						{
							"path": "dist/index.js"
						}
					]
				}
			]
		]
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && yarn package",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package && publint --pack npm",
		"prepublishOnly": "yarn package",
		"pretest": "svelte-kit sync",
		"test": "vitest watch --coverage",
		"test:ci": "vitest run --coverage",
		"lint": "prettier --check .",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"prettier": "prettier \"*/**/*.{js,ts,svelte}\" --ignore-path ./.prettierignore --write && git add -u && git status",
		"prepare": "husky"
	}
}
